{
  "name": "detoks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "detoks": "bin/detoks.js"
  },
  "engines": {
    "node": ">=24.15.0 <26"
  },
  "scripts": {
    "add:py": "node scripts/add-py-dep.mjs",
    "add:py:dev": "node scripts/add-py-dev-dep.mjs",
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "cli": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:role1": "tsx scripts/verify-role1.ts",
    "verify:role1:rows": "tsx scripts/verify-role1.ts --file tests/data/row_data.json",
    "benchmark": "tsx scripts/benchmark-pipeline.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "tiktoken": "^1.0.22",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.3.1",
    "tsx": "4.20.5",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
